        <mxCell id="bfkDZkSz8QxWnvJyUEP_-17" parent="1" style="whiteSpace=wrap;html=1;rounded=0;" value="要素上传" vertex="1">
          <mxGeometry height="60" width="120" x="60" y="486.25" as="geometry" />
        </mxCell>
        <mxCell id="bfkDZkSz8QxWnvJyUEP_-22" edge="1" parent="1" source="bfkDZkSz8QxWnvJyUEP_-19" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="bfkDZkSz8QxWnvJyUEP_-21" value="">
